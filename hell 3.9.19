[32m+[m[32m                    if file_path.exists():[m
[32m+[m[32m                        with open(file_path, encoding='utf8') as temp_file:[m
[32m+[m[32m                            return temp_file.read()[m
[32m+[m[32m                    else:[m
[32m+[m[32m                        self.logger.warning(f'File not found: {file_path}')[m
[32m+[m[32m                        return ''[m
[32m+[m[32m            except Exception as e:[m
[32m+[m[32m                self.logger.debug(f'Error mapping to source file: {e}, reading from temporary file')[m
[32m+[m[32m                if file_path.exists():[m
[32m+[m[32m                    with open(file_path, encoding='utf8') as temp_file:[m
[32m+[m[32m                        return temp_file.read()[m
[32m+[m[32m                else:[m
[32m+[m[32m                    self.logger.warning(f'File not found: {file_path}')[m
[32m+[m[32m                    return ''[m
[32m+[m[32m        else:[m
