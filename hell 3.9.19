[32m+[m[32m            to_end: bool = False[m
[32m+[m[32m    ) -> (str, list):[m
[32m+[m[32m        '''Process include statement specifically for includes_map generation.[m
[32m+[m[32m        Reads content from source files directly, not from temporary directory.[m
[32m+[m[41m        [m
[32m+[m[32m        :param included_file_path: Path to the included file[m
[32m+[m[32m        :param from_heading: Include starting from this heading[m
[32m+[m[32m        :param to_heading: Include up to this heading[m
[32m+[m[32m        :param from_id: Include starting from the heading or the anchor that has this ID[m
[32m+[m[32m        :param to_id: Include up to the heading or the anchor that has this ID[m
[32m+[m[32m        :param to_end: Flag that tells to cut to the end of document[m
[32m+[m[41m        [m
[32m+[m[32m        :returns: Tuple of (included file content, list of anchors)[m
[32m+[m[32m        '''[m
[32m+[m[41m        [m
[32m+[m[32m        self.logger.debug(f'Processing include for includes_map: {included_file_path}')[m
[32m+[m[41m        [m
[32m+[m[32m        anchors = [][m
[32m+[m[41m        [m
[32m+[m[32m        # Reading the contents of the file from the source directory[m
[32m+[m[32m        content = self._read_source_file_content(included_file_path)[m
[32m+[m[41m        [m
[32m+[m[32m        if not content:[m
[32m+[m[32m            return '', anchors[m
[32m+[m[41m        [m
[32m+[m[32m        # Check if the file has not_build: true[m
[32m+[m[32m        if self._has_not_build_meta(content):[m
[32m+[m[32m            self.logger.debug(f'File {included_file_path} has not_build: true, using original content')[m
[32m+[m[41m        [m
[32m+[m[32m        # Removing metadata from content[m
[32m+[m[32m        content = remove_meta(content)[m
[32m+[m[41m        [m
[32m+[m[32m        # Cut content based on parameters[m
[32m+[m[32m        content = self._cut_from_position_to_position([m
[32m+[m[32m            content,[m
[32m+[m[32m            from_heading,[m
[32m+[m[32m            to_heading,[m
[32m+[m[32m            from_id,[m
[32m+[m[32m            to_id,[m
[32m+[m[32m            to_end[m
[32m+[m[32m        )[m
[32m+[m[41m        [m
[32m+[m[32m        # Find anchors[m
[32m+[m[32m        if self.includes_map_anchors:[m
[32m+[m[32m            anchors = self._add_anchors(anchors, content)[m
[32m+[m[41m        [m
[32m+[m[32m        return content, anchors[m
