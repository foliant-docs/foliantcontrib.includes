[32m+[m[32m    def _read_source_file_content([m
[32m+[m[32m            self,[m
[32m+[m[32m            file_path: Path[m
[32m+[m[32m    ) -> str:[m
[32m+[m[32m        '''Read content from source file, handling both temporary and source directory paths.[m
[32m+[m[41m        [m
[32m+[m[32m        :param file_path: Path to the file to read[m
[32m+[m[41m        [m
[32m+[m[32m        :returns: File content as string[m
[32m+[m[32m        '''[m
[32m+[m[41m        [m
[32m+[m[32m        self.logger.debug(f'Reading source file: {file_path}')[m
[32m+[m[41m        [m
[32m+[m[32m        # If the file is located in a temporary directory, let's try to find the corresponding source file[m
[32m+[m[32m        if self.working_dir.resolve() in file_path.parents:[m
[32m+[m[32m            # This is a file in a temporary directory[m
[32m+[m[32m            try:[m
[32m+[m[32m                # Get the path to the source file[m
[32m+[m[32m                src_file_path = self._get_src_file_path(file_path)[m
