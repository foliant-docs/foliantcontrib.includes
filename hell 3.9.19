[32m+[m[32m    def _has_not_build_meta(self, content: str) -> bool:[m
[32m+[m[32m        '''Check if content has not_build: true in front matter.[m
[32m+[m[41m        [m
[32m+[m[32m        :param content: File content[m
[32m+[m[41m        [m
[32m+[m[32m        :returns: True if file has not_build: true in metadata[m
[32m+[m[32m        '''[m
[32m+[m[32m        # Simple check for front matter with not_build: true[m
[32m+[m[32m        front_matter_pattern = re.compile(r'^---\s*\n(.*?)\n---\s*\n', re.DOTALL | re.MULTILINE)[m
[32m+[m[32m        match = front_matter_pattern.match(content)[m
[32m+[m[41m        [m
[32m+[m[32m        if match:[m
[32m+[m[32m            front_matter = match.group(1)[m
[32m+[m[32m            # Check for not_build: true[m
[32m+[m[32m            not_build_pattern = re.compile(r'not_build\s*:\s*true', re.IGNORECASE)[m
[32m+[m[32m            return bool(not_build_pattern.search(front_matter))[m
[32m+[m[41m        [m
[32m+[m[32m        return False[m
